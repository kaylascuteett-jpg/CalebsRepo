local function makeContainer(labelText)
    local container = Instance.new("Frame")
    container.Size = UDim2.fromOffset(204, 42)
    container.BackgroundTransparency = 1
    container.Parent = frame
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.fromOffset(204, 16)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(220, 220, 220)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Text = labelText
    label.Font = Enum.Font.SourceSans
    label.TextSize = 13
    label.Parent = container
    
    return container
end

local function makeBox(container, default, callback)
    local box = Instance.new("TextBox")
    box.Size = UDim2.fromOffset(204, 22)
    box.Position = UDim2.new(0, 0, 0, 18)
    box.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    box.TextColor3 = Color3.fromRGB(255, 255, 255)
    box.BorderSizePixel = 0
    box.Text = tostring(default)
    box.ClearTextOnFocus = false
    box.Font = Enum.Font.SourceSans
    box.TextSize = 13
    box.Parent = container
    box.FocusLost:Connect(function()
        local v = tonumber(box.Text)
        if v then callback(v) end
    end)
end

local function makeToggle(container, default, callback)
    local toggle = Instance.new("TextButton")
    toggle.Size = UDim2.fromOffset(204, 22)
    toggle.Position = UDim2.new(0, 0, 0, 18)
    toggle.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    toggle.TextColor3 = Color3.fromRGB(255, 255, 255)
    toggle.BorderSizePixel = 0
    toggle.Text = default and "ON" or "OFF"
    toggle.Font = Enum.Font.SourceSans
    toggle.TextSize = 13
    toggle.Parent = container
    
    local state = default
    toggle.MouseButton1Click:Connect(function()
        state = not state
        toggle.Text = state and "ON" or "OFF"
        callback(state)
    end)
end

local function makeKeybindBox(label, defaultKey, setFunc)
    local c = makeContainer(label)
    local keyBox = Instance.new("TextBox")
    keyBox.Size = UDim2.fromOffset(204, 22)
    keyBox.Position = UDim2.new(0, 0, 0, 18)
    keyBox.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    keyBox.TextColor3 = Color3.fromRGB(200, 255, 200)
    keyBox.BorderSizePixel = 0
    keyBox.Text = defaultKey.Name
    keyBox.ClearTextOnFocus = false
    keyBox.Font = Enum.Font.SourceSans
    keyBox.TextSize = 13
    keyBox.Parent = c
    
    keyBox.FocusLost:Connect(function(enterPressed)
        if not enterPressed then return end
        local input = keyBox.Text:lower():gsub("%s+", ""):gsub("[^%w]", "")
        local aliases = {
            up = "Up", down = "Down", left = "Left", right = "Right",
            ctrl = "LeftControl", lctrl = "LeftControl", rctrl = "RightControl",
            control = "LeftControl", alt = "LeftAlt", shift = "LeftShift",
            enter = "Return", esc = "Escape", del = "Delete", ins = "Insert",
            home = "Home", ["end"] = "End", pgup = "PageUp", pgdn = "PageDown",
            caps = "CapsLock", capslock = "CapsLock",
            f1 = "F1", f2 = "F2", f3 = "F3", f4 = "F4", f5 = "F5", f6 = "F6",
            f7 = "F7", f8 = "F8", f9 = "F9", f10 = "F10", f11 = "F11", f12 = "F12",
            a = "A", b = "B", c = "C", d = "D", e = "E", f = "F", g = "G", h = "H",
            i = "I", j = "J", k = "K", l = "L", m = "M", n = "N", o = "O", p = "P",
            q = "Q", r = "R", s = "S", t = "T", u = "U", v = "V", w = "W", x = "X",
            y = "Y", z = "Z",
            ["1"] = "One", ["2"] = "Two", ["3"] = "Three", ["4"] = "Four", ["5"] = "Five",
            ["6"] = "Six", ["7"] = "Seven", ["8"] = "Eight", ["9"] = "Nine", ["0"] = "Zero",
            num0 = "KeypadZero", num1 = "KeypadOne", num2 = "KeypadTwo", num3 = "KeypadThree",
            num4 = "KeypadFour", num5 = "KeypadFive", num6 = "KeypadSix", num7 = "KeypadSeven",
            num8 = "KeypadEight", num9 = "KeypadNine",
            space = "Space", tilde = "Tilde", minus = "Minus", equals = "Equals",
        }
        if aliases[input] then input = aliases[input] end
        
        local success, key = pcall(function() return Enum.KeyCode[input] end)
        if success and key and key ~= Enum.KeyCode.Unknown then
            setFunc(key)
            keyBox.TextColor3 = Color3.fromRGB(150, 255, 150)
            keyBox.Text = key.Name
        else
            keyBox.TextColor3 = Color3.fromRGB(255, 150, 150)
            keyBox.Text = "Invalid"
            task.delay(1.2, function()
                if keyBox and keyBox.Parent then
                    keyBox.TextColor3 = Color3.fromRGB(200, 255, 200)
                    keyBox.Text = defaultKey.Name
                end
            end)
        end
    end)
end

