    if input.KeyCode == getgenv().ButtonToggleKey then
        toggleButton.Visible = not toggleButton.Visible
        if not toggleButton.Visible then frame.Visible = false end
    end
end)

-- Specific lock hotkey
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if getgenv().SpecificSilentEnabled and input.KeyCode == getgenv().SpecificLockKey then
        local mouse = LocalPlayer:GetMouse()
        local target = mouse.Target
        if target then
            local character = target
            while character and not character:FindFirstChild("Humanoid") and character.Parent do
                character = character.Parent
            end
            local player = character and Players:GetPlayerFromCharacter(character)
            if player and player ~= LocalPlayer then
                if SpecificLockedPlayer == player then
                    SpecificLockedPlayer = nil
                    game:GetService("StarterGui"):SetCore("SendNotification", {
                        Title = "Caleb's Silent Aim",
                        Text = "Unlocked from " .. player.Name,
                        Duration = 1.8
                    })
                else
                    SpecificLockedPlayer = player
                    game:GetService("StarterGui"):SetCore("SendNotification", {
                        Title = "Caleb's Silent Aim",
                        Text = "Locked onto " .. player.Name,
                        Duration = 1.8
                    })
                end
            end
        end
    end
end)

