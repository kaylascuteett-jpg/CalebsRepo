    whitelistBox.Position = UDim2.new(0, 0, 0, 25)
    whitelistBox.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    whitelistBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    whitelistBox.BorderSizePixel = 0
    whitelistBox.Text = table.concat(getgenv().Whitelist or {}, ", ")
    whitelistBox.ClearTextOnFocus = false
    whitelistBox.Parent = whitelistContainer
    whitelistBox.FocusLost:Connect(function()
        local text = whitelistBox.Text or ""
        getgenv().Whitelist = {}
        for _, name in ipairs(string.split(text, ",")) do
            local trimmed = name:match("^%s*(.-)%s*$")
            if trimmed and trimmed ~= "" then
                table.insert(getgenv().Whitelist, trimmed)
            end
        end
    end)
    
    makeToggle(makeContainer("Use Blacklist"), getgenv().UseBlacklist, function(v) getgenv().UseBlacklist = v end)
    local blacklistContainer = makeContainer("Blacklist Players (comma separated)")
    local blacklistBox = Instance.new("TextBox")
