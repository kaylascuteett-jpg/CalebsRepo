    makeToggle( makeContainer("Silent Aim"), true, function(v) getgenv().SilentAimEnabled = v end)
    makeToggle( makeContainer("Wall Check"), false, function(v) Aiming.VisibleCheck = v end)
    
    -- NEW: Whitelist / Blacklist (exclude/include) textboxes
    makeToggle(makeContainer("Use Whitelist"), getgenv().UseWhitelist, function(v) getgenv().UseWhitelist = v end)
    local whitelistContainer = makeContainer("Whitelist Players (comma separated)")
    local whitelistBox = Instance.new("TextBox")
