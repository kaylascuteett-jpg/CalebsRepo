local function createButton(text, callback)
    local button = Instance.new("TextButton")
    button.Size = UDim2.new(1,0,0,56)
    button.BackgroundColor3 = Color3.fromRGB(0, 120, 255)
    button.Text = text
    button.TextColor3 = Color3.new(1,1,1)
